# Copy this file to ".env" and fill in real values.
# In production (Render/Railway) set these as environment variables instead.

# Server
PORT=5000
NODE_ENV=development
# In production set this to your deployed URL, e.g. https://your-app.onrender.com
CLIENT_URL=http://localhost:5173

# MongoDB connection string (Atlas)
MONGO_URI=your_mongodb_connection_string

# JWT secrets (use long, random, DIFFERENT values for each)
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Redis (Upstash) — must be a rediss:// (TLS) URL with the read/write password
UPSTASH_REDIS_URL=rediss://default:your_password@your-host.upstash.io:6379

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (payments) — backend needs the SECRET key (sk_...)
STRIPE_SECRET_KEY=your_stripe_secret_key
